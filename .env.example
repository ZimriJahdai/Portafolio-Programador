# URL publica del frontend para CORS del backend
CLIENT_ORIGIN=http://localhost:8080

# API que se inyecta al build del frontend. Con nginx proxy, dejar /api.
VITE_API_URL=/api

# MongoDB Atlas para persistir registros reales del backend
MONGODB_URI=mongodb+srv://usuario:password@tu-cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=portafolio

# SMTP (necesario para enviar correos reales)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_password_de_aplicacion
MAIL_FROM=tu_correo@gmail.com
OWNER_EMAIL=tu_correo@gmail.com

# Ruta del CV dentro del contenedor backend
CV_FILE_PATH=./assets/CV-Zimri-Lopez.pdf
